{{#if jsDoc.length}}
/**
{{#each jsDoc}}
 * {{this}}
{{/each}}
 */
{{/if}}
export async function {{operationId}}(
  {{#each pathParameters}}
  {{name}}: {{schemaName}},
  {{/each}}
  {{#if queryParameters}}
  queryParams: {{queryParameters.schemaName}},
  {{/if}}
  {{#if requestBody}}
  requestBody: {{requestBody.schemaName}},
  {{/if}}
) {
  {{#if queryParameters}}
  const url = createURL({{{endpoint}}}, parseZodSchema(schemaOf{{queryParams.schemaName}}, queryParams));
  {{else}}
  const url = createURL({{{endpoint}}});
  {{/if}}
  const response = await fetch(url, {
    method: "{{method}}",
    headers: {
      "Content-Type": "application/json",
    },
    {{#if requestBody}}
    body: JSON.stringify(parseZodSchema(schemaOf{{requestBody.schemaName}}, requestBody)),
    {{/if}}
  });
  switch (response.status) {
    {{#each responses}}
    case {{statusCode}}: {
      {{#if schemaName}}
      const content = await response.json() as {{schemaName}};
      {{else}}
      const content = null;
      {{/if}}
      return {
        success: response.ok,
        content,
      };
    }
    {{/each}}
    default: {
      throw new Error(`Undocumented response from {{operationId}} ({{method}} ${ {{~{endpoint}~}} })`);
    }
  }
}
